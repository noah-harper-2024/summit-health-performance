---
import { SITE, NAV_LINKS } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-grid">
    <div class="footer-brand">
      <div class="footer-name">{SITE.name}</div>
      <p>Sports chiropractic for active adults and youth athletes in Huntsville, AL — fixing the root cause, not just the symptom.</p>
      <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" class="ig-link">
        {SITE.social.instagramHandle}
      </a>
    </div>

    <div class="footer-col">
      <h4>Visit</h4>
      <p class="addr">
        <a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer">
          {SITE.address.street}<br />{SITE.address.city}, {SITE.address.state} {SITE.address.zip}
        </a>
      </p>
      <a href={SITE.phoneHref} class="phone">{SITE.phone}</a>
      <a href={`mailto:${SITE.email}`} class="email">{SITE.email}</a>
    </div>

    <div class="footer-col">
      <h4>Hours</h4>
      <ul class="hours">
        {SITE.hours.map((h) => (
          <li><span>{h.days}</span><span>{h.time}</span></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h4>Site</h4>
      <ul class="links">
        {NAV_LINKS.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <span>© {year} {SITE.name}. All rights reserved.</span>
      <span>Huntsville, Alabama</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy);
    color: var(--bg);
    font-family: var(--font-body);
  }
  .footer-grid {
    max-width: var(--maxw);
    margin-inline: auto;
    padding: 4.5rem 2rem 2.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .footer-name {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 1.35rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.9rem;
  }
  .footer-brand p {
    color: #a9b2c8;
    font-size: 0.95rem;
    line-height: 1.65;
    max-width: 34ch;
    margin: 0 0 1.2rem;
  }
  .ig-link { color: var(--steel-light); font-size: 0.9rem; font-weight: 500; }
  .ig-link:hover { color: var(--white); }

  .footer-col h4 {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--steel);
    margin: 0 0 1.1rem;
  }
  .footer-col a { color: var(--steel-light); font-size: 0.92rem; }
  .footer-col a:hover { color: var(--white); }
  .addr { margin: 0 0 0.9rem; line-height: 1.7; }
  .footer-col .phone { display: block; color: var(--white); font-weight: 600; margin-bottom: 0.4rem; }

  .hours, .links { list-style: none; padding: 0; margin: 0; }
  .hours li {
    display: flex; justify-content: space-between; gap: 1rem;
    font-size: 0.88rem; color: var(--steel-light); padding: 0.15rem 0;
  }
  .hours span:first-child { color: #a9b2c8; }
  .links li { margin-bottom: 0.6rem; }

  .footer-bottom { border-top: 1px solid rgba(255, 255, 255, 0.1); }
  .footer-bottom-inner {
    max-width: var(--maxw);
    margin-inline: auto;
    padding: 1.4rem 2rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .footer-bottom-inner span { font-size: 0.78rem; color: #7783a0; }

  @media (min-width: 560px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 960px) {
    .footer-grid { grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: 3rem; }
  }
</style>
