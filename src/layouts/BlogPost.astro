---
import BaseLayout from './BaseLayout.astro';
import BookNow from '../components/BookNow.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, heroImage } = post.data;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<BaseLayout title={title} description={description} image={heroImage?.src}>
  <article class="post">
    <a href="/blog/" class="back">← Back to Journal</a>
    <div class="meta">
      <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time> · {author}
      {updatedDate && <> · Updated {fmt(updatedDate)}</>}
    </div>
    <h1>{title}</h1>

    {heroImage && (
      <figure class="hero">
        <Image src={heroImage} alt={title} widths={[480, 760]} sizes="(max-width: 800px) 100vw, 760px" />
      </figure>
    )}

    <div class="prose">
      <slot />
    </div>

    <div class="post-cta">
      <BookNow />
    </div>
  </article>
</BaseLayout>

<style>
  .post { max-width: 760px; margin: 0 auto; padding: 5.5rem 2rem 7.5rem; }
  .back {
    font-family: var(--font-body); font-weight: 600; font-size: 14px;
    color: var(--muted); display: inline-block; margin-bottom: 2rem;
  }
  .back:hover { color: var(--blue-bright); }
  .meta {
    font-family: var(--font-head); font-weight: 600; font-size: 12.5px;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--steel); margin-bottom: 1rem;
  }
  .post h1 {
    font-family: var(--font-head); font-weight: 800;
    font-size: clamp(2rem, 4vw, 2.8rem); line-height: 1.1;
    letter-spacing: -0.02em; color: var(--navy); margin: 0 0 2.75rem;
  }
  .hero { margin: 0 0 2.75rem; background: var(--bg-soft); padding: 0.75rem; border: 1px solid var(--line); }
  .hero :global(img) { width: 100%; height: auto; display: block; }

  .prose :global(p) { font-size: 18px; line-height: 1.75; color: #333c4d; margin: 0 0 1.5rem; }
  .prose :global(h2) {
    font-family: var(--font-head); font-weight: 700; font-size: 26px;
    color: var(--navy); margin: 3rem 0 1.1rem; letter-spacing: -0.01em;
  }
  .prose :global(h3) { font-family: var(--font-head); font-weight: 700; font-size: 20px; color: var(--navy); margin: 2rem 0 0.8rem; }
  .prose :global(ul), .prose :global(ol) { font-size: 18px; line-height: 1.75; color: #333c4d; margin: 0 0 1.5rem; padding-left: 1.3rem; }
  .prose :global(blockquote) {
    margin: 0 0 1.5rem; padding: 0.9rem 1.4rem;
    border-left: 3px solid var(--blue-bright); background: var(--bg-soft);
    color: var(--muted); font-size: 16px; font-style: italic;
  }
  .prose :global(a) { color: var(--blue-bright); text-decoration: underline; }
  .prose :global(a:hover) { color: var(--blue); }
  .prose :global(hr) { border: 0; border-top: 1px solid var(--line); margin: 2.5rem 0; }
  .prose :global(code) { background: var(--bg-soft); padding: 0.1em 0.4em; border-radius: 2px; font-size: 0.92em; }

  .post-cta { margin-top: 3.5rem; padding-top: 2rem; border-top: 1px solid var(--line); }
</style>
