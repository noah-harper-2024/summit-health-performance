---
import BaseLayout from './BaseLayout.astro';
import BookNow from '../components/BookNow.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, heroImage, tags } = post.data;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<BaseLayout title={title} description={description} image={heroImage?.src}>
  <article class="post">
    <header class="post-header">
      <div class="container post-header-inner">
        <a href="/blog/" class="back-link">← All articles</a>
        {tags.length > 0 && (
          <div class="tags">{tags.map((t) => <span class="tag">{t}</span>)}</div>
        )}
        <h1>{title}</h1>
        <p class="post-meta">
          By {author} · <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
          {updatedDate && <> · Updated {fmt(updatedDate)}</>}
        </p>
      </div>
    </header>

    {heroImage && (
      <div class="container">
        <Image src={heroImage} alt={title} class="post-hero" widths={[480, 800, 1200]} sizes="(max-width: 900px) 100vw, 900px" />
      </div>
    )}

    <div class="container">
      <div class="post-body">
        <slot />
      </div>

      <div class="post-cta">
        <h3>Want help putting this into practice?</h3>
        <p>Book a visit with Dr. Seth Graham and get a plan built around your goals.</p>
        <BookNow size="lg" />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-header { padding-block: clamp(2.5rem, 6vw, 4rem) 1.5rem; background: var(--bg-soft); }
  .post-header-inner { max-width: 760px; margin-inline: auto; }
  .back-link { font-family: var(--font-head); font-weight: 600; font-size: 0.9rem; }
  .post-header h1 { margin: 1rem 0 0.8rem; }
  .post-meta { color: var(--muted); margin: 0; font-size: 0.95rem; }

  .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 1rem; }
  .tag {
    font-size: 0.74rem; font-weight: 600; color: var(--blue);
    background: var(--bg-tint); padding: 0.2rem 0.6rem; border-radius: 999px;
  }

  .post-hero {
    width: 100%;
    max-width: 900px;
    margin: 2rem auto 0;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    height: auto;
  }

  .post-body {
    max-width: 720px;
    margin: 2.5rem auto 0;
    font-size: 1.1rem;
  }
  .post-body :global(h2) { margin-top: 2.2rem; }
  .post-body :global(h3) { margin-top: 1.8rem; }
  .post-body :global(img) { border-radius: var(--radius); margin: 1.5rem 0; box-shadow: var(--shadow-sm); }
  .post-body :global(blockquote) {
    border-left: 4px solid var(--blue-bright);
    margin: 1.5rem 0;
    padding: 0.4rem 0 0.4rem 1.4rem;
    color: var(--muted);
    font-style: italic;
  }
  .post-body :global(a) { text-decoration: underline; }
  .post-body :global(code) {
    background: var(--bg-tint);
    padding: 0.1em 0.4em;
    border-radius: 6px;
    font-size: 0.9em;
  }
  .post-body :global(hr) { border: 0; border-top: 1px solid var(--line); margin: 2.5rem 0; }

  .post-cta {
    max-width: 720px;
    margin: 3.5rem auto 4.5rem;
    padding: 2.2rem;
    background: var(--bg-tint);
    border-radius: var(--radius-lg);
    text-align: center;
  }
  .post-cta p { color: var(--muted); margin-bottom: 1.4rem; }
</style>
