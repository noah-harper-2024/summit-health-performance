---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookNow from '../components/BookNow.astro';

const steps = [
  { num: '01', title: 'Assess', desc: 'A full movement and history review to find what’s actually driving the problem.' },
  { num: '02', title: 'Adjust', desc: 'Hands-on chiropractic care targeted at the joints and tissue that need it most.' },
  { num: '03', title: 'Rebuild', desc: 'A movement plan that restores capacity so the problem doesn’t just come back.' },
];
---

<BaseLayout title="About" description="Meet Dr. Seth Graham and learn how Summit Health & Performance builds care around the root cause — not the symptom — for active adults and youth athletes in Huntsville, AL.">
  <section class="intro">
    <div class="eyebrow">About Summit</div>
    <h1>Care built around the root cause, not the symptom.</h1>
    <p class="lead">
      Summit Health &amp; Performance is a sports chiropractic clinic in Huntsville, AL — founded
      on the idea that lasting relief comes from fixing what's actually wrong, not chasing pain
      around the body.
    </p>
  </section>

  <section class="bio">
    <figure class="bio-photo">
      <img src="/images/photos/dr-graham-headshot.jpg" alt="Dr. Seth Graham" width="431" height="618" />
    </figure>
    <div class="bio-copy">
      <div class="eyebrow">Dr. Seth Graham</div>
      <h2>Sports chiropractor, movement coach</h2>
      <p>Dr. Graham built Summit around a simple frustration: too many active people get told to rest, stretch, and wait — without ever learning why the pain showed up in the first place.</p>
      <p>His approach pairs hands-on chiropractic care with a real movement assessment, so every plan is built around your body, your sport, and your goals — not a generic protocol.</p>
      <p>Outside the clinic, he trains like his patients do — which is exactly why he understands what it takes to get back to it.</p>
    </div>
  </section>

  <section class="how">
    <div class="how-inner">
      <h2>How we work</h2>
      <div class="steps">
        {steps.map((s) => (
          <div class="step">
            <div class="step-num">{s.num}</div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="assess">
    <figure class="assess-photo">
      <img src="/images/photos/movement-assessment.jpg" alt="Movement assessment at Summit Health & Performance" width="204" height="201" loading="lazy" />
    </figure>
    <p>Every plan starts on the table with a movement assessment — how you squat, rotate, and load — so treatment targets the actual source, not just where it hurts today.</p>
  </section>

  <section class="cta">
    <div class="cta-inner">
      <h2>Let's find your root cause.</h2>
      <BookNow variant="on-navy" size="lg" />
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-head);
    font-weight: 700; font-size: 13px; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--blue-bright);
    margin-bottom: 1.2rem; display: block;
  }
  h1, h2 { font-family: var(--font-head); color: var(--navy); letter-spacing: -0.02em; margin: 0; }

  .intro { max-width: var(--maxw); margin: 0 auto; padding: 5.5rem 2rem 0; }
  .intro h1 { font-weight: 800; font-size: clamp(2.4rem, 4.4vw, 4rem); line-height: 1.04; max-width: 16ch; margin-bottom: 1.6rem; }
  .intro .lead { font-size: 19px; line-height: 1.65; color: var(--muted); max-width: 60ch; margin: 0; }

  .bio {
    max-width: var(--maxw); margin: 0 auto; padding: 3.5rem 2rem 6rem;
    display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: center;
  }
  .bio-photo { margin: 0; background: var(--bg-soft); padding: 1.1rem; border: 1px solid var(--line); max-width: 300px; }
  .bio-photo img { width: 100%; height: auto; object-fit: cover; display: block; }
  .bio-copy h2 { font-weight: 800; font-size: clamp(1.8rem, 3vw, 2.4rem); letter-spacing: -0.01em; margin-bottom: 1.4rem; }
  .bio-copy p { font-size: 18px; line-height: 1.7; color: var(--muted); max-width: 56ch; margin: 0 0 1.25rem; }
  @media (min-width: 860px) { .bio { grid-template-columns: 0.85fr 1.15fr; gap: 4rem; } }

  .how { background: var(--bg-soft); padding: 6rem 0; }
  .how-inner { max-width: var(--maxw); margin: 0 auto; padding: 0 2rem; }
  .how h2 { font-weight: 800; font-size: clamp(1.8rem, 3vw, 2.3rem); letter-spacing: -0.01em; margin-bottom: 3rem; }
  .steps { display: grid; grid-template-columns: 1fr; gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .step { background: var(--bg); padding: 2.5rem 2.25rem; display: flex; flex-direction: column; gap: 0.9rem; }
  .step-num { font-family: var(--font-head); font-weight: 800; font-size: 15px; color: var(--blue-bright); }
  .step h3 { font-family: var(--font-head); font-weight: 700; font-size: 20px; color: var(--navy); margin: 0; }
  .step p { font-size: 15px; line-height: 1.65; color: var(--muted); margin: 0; }
  @media (min-width: 780px) { .steps { grid-template-columns: repeat(3, 1fr); } }

  .assess {
    max-width: var(--maxw); margin: 0 auto; padding: 6rem 2rem;
    display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: center;
  }
  .assess-photo { margin: 0; background: var(--bg-soft); padding: 1.1rem; border: 1px solid var(--line); max-width: 280px; }
  .assess-photo img { width: 100%; height: auto; object-fit: cover; display: block; }
  .assess p { font-size: 18px; line-height: 1.7; color: var(--muted); margin: 0; max-width: 48ch; }
  @media (min-width: 780px) { .assess { grid-template-columns: 1fr 1fr; gap: 3.5rem; } }

  .cta { background: var(--navy); padding: 6rem 0; }
  .cta-inner { max-width: 900px; margin: 0 auto; padding: 0 2rem; text-align: center; }
  .cta h2 { font-weight: 800; font-size: clamp(2rem, 4vw, 3rem); color: var(--bg); margin-bottom: 2rem; }
</style>
