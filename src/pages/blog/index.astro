---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<BaseLayout title="Journal" description="Notes on training, recovery, mobility, and longevity from Dr. Seth Graham at Summit Health & Performance.">
  <section class="intro">
    <div class="eyebrow">Journal</div>
    <h1>Notes on training, recovery, and moving well.</h1>
  </section>

  {posts.length === 0 ? (
    <section class="empty-wrap"><p class="empty">New articles are on the way — check back soon.</p></section>
  ) : (
    <section class="posts">
      {posts.map((post) => (
        <a href={`/blog/${post.id}/`} class="post">
          <div class="post-date">{fmt(post.data.pubDate)}</div>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <span class="read">Read more →</span>
        </a>
      ))}
    </section>
  )}
</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-head);
    font-weight: 700; font-size: 13px; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--blue-bright);
    margin-bottom: 1.2rem; display: block;
  }
  h1 { font-family: var(--font-head); color: var(--navy); letter-spacing: -0.02em; margin: 0; }

  .intro { max-width: var(--maxw); margin: 0 auto; padding: 5.5rem 2rem 4rem; }
  .intro h1 { font-weight: 800; font-size: clamp(2.4rem, 4.4vw, 3.6rem); line-height: 1.05; max-width: 18ch; }

  .posts {
    max-width: var(--maxw); margin: 0 auto; padding: 0 2rem 7.5rem;
    display: grid; grid-template-columns: 1fr; gap: 1px;
    background: var(--line); border: 1px solid var(--line);
  }
  .post {
    background: var(--bg); padding: 2.75rem 2.5rem;
    display: flex; flex-direction: column; gap: 1rem; transition: background 160ms ease;
  }
  .post:hover { background: var(--bg-soft); }
  .post-date {
    font-family: var(--font-head); font-weight: 600; font-size: 12.5px;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--steel);
  }
  .post h2 { font-family: var(--font-head); font-weight: 700; font-size: 24px; color: var(--navy); margin: 0; letter-spacing: -0.01em; }
  .post p { font-size: 15.5px; line-height: 1.65; color: var(--muted); margin: 0; }
  .read { font-family: var(--font-body); font-weight: 600; font-size: 14px; color: var(--navy); margin-top: 0.5rem; }

  .empty-wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 2rem 7rem; }
  .empty { color: var(--muted); font-size: 1.1rem; }

  @media (min-width: 720px) { .posts { grid-template-columns: repeat(2, 1fr); } }
</style>
