---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookNow from '../components/BookNow.astro';
import { SITE } from '../data/site';
---

<BaseLayout title="Contact" description="Visit Summit Health & Performance at 3070 Leeman Ferry Rd SW, Huntsville, AL. Call 256-947-2660 or book your appointment online.">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Get in Touch</span>
      <h1>Visit Summit Health &amp; Performance</h1>
      <p class="lead">
        We're located in Huntsville, AL and ready to help you move better. Book online any time,
        or reach out with questions.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-info">
        <div class="info-block">
          <h3>Location</h3>
          <a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer">
            {SITE.address.street}<br />{SITE.address.city}, {SITE.address.state} {SITE.address.zip}
          </a>
        </div>
        <div class="info-block">
          <h3>Phone</h3>
          <a href={SITE.phoneHref}>{SITE.phone}</a>
        </div>
        <div class="info-block">
          <h3>Email</h3>
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </div>
        <div class="info-block">
          <h3>Instagram</h3>
          <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer">
            {SITE.social.instagramHandle}
          </a>
        </div>
        <div class="info-block">
          <h3>Hours</h3>
          <ul class="hours">
            {SITE.hours.map((h) => (
              <li><span>{h.days}</span><span>{h.time}</span></li>
            ))}
          </ul>
        </div>
      </div>

      <aside class="book-panel">
        <h2>Book your appointment</h2>
        <p>
          The fastest way to get started is to book online. Choose a time that fits your schedule
          and we'll take it from there.
        </p>
        <BookNow size="lg" />
        <p class="panel-note">
          Prefer to talk first? Call us at <a href={SITE.phoneHref}>{SITE.phone}</a>.
        </p>
      </aside>
    </div>
  </section>

  <section class="map-section" aria-label="Map">
    <iframe
      title={`Map to ${SITE.name}`}
      src="https://www.google.com/maps?q=3070+Leeman+Ferry+Rd+SW,+Huntsville,+AL&output=embed"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-block: clamp(3rem, 7vw, 5rem) clamp(1rem, 3vw, 2rem);
    background:
      radial-gradient(900px 380px at 85% -20%, var(--bg-tint), transparent 60%),
      var(--white);
  }
  .page-hero .lead { margin-top: 0.5rem; }

  .contact-grid { display: grid; gap: 2.5rem; align-items: start; }
  .info-block { margin-bottom: 1.8rem; }
  .info-block h3 {
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blue-bright);
    margin-bottom: 0.4rem;
  }
  .info-block a { color: var(--ink); font-size: 1.05rem; }
  .info-block a:hover { color: var(--blue-bright); }
  .hours { list-style: none; padding: 0; margin: 0; max-width: 320px; }
  .hours li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.3rem 0;
    border-bottom: 1px dashed var(--line);
  }
  .hours span:first-child { color: var(--muted); }

  .book-panel {
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 2.2rem;
    box-shadow: var(--shadow-sm);
  }
  .book-panel p { color: var(--muted); }
  .book-panel .btn { margin: 0.6rem 0 1rem; }
  .panel-note { font-size: 0.95rem; }

  @media (min-width: 860px) {
    .contact-grid { grid-template-columns: 1fr 0.9fr; gap: 3.5rem; }
  }

  .map-section { line-height: 0; }
  .map-section iframe {
    width: 100%;
    height: 420px;
    border: 0;
    border-top: 1px solid var(--line);
  }
</style>
