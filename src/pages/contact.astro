---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookNow from '../components/BookNow.astro';
import { SITE } from '../data/site';
---

<BaseLayout title="Contact" description="Visit Summit Health & Performance at 3070 Leeman Ferry Rd SW, Huntsville, AL. Call 256-947-2660, send a message, or book online.">
  <section class="contact">
    <div class="contact-info">
      <div class="eyebrow">Contact</div>
      <h1>Let's get you moving again.</h1>
      <p class="lead">Booking online is the fastest way in. For anything else, reach us directly below.</p>

      <div class="details">
        <div class="detail">
          <div class="label">Address</div>
          <a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer">{SITE.address.full}</a>
        </div>
        <div class="detail">
          <div class="label">Phone</div>
          <a href={SITE.phoneHref}>{SITE.phone}</a>
        </div>
        <div class="detail">
          <div class="label">Email</div>
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </div>
        <div class="detail">
          <div class="label">Hours</div>
          <div class="hours">
            {SITE.hours.map((h) => (
              <div class="hour-row"><span>{h.days}</span><span>{h.time}</span></div>
            ))}
          </div>
        </div>
      </div>

      <BookNow />
    </div>

    <div class="form-panel">
      <h2>Send a message</h2>
      <p class="form-note">Not urgent, or want to ask before booking? Send a note and we'll get back to you.</p>
      <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="contact-form">
        <input type="hidden" name="form-name" value="contact" />
        <p class="hp"><label>Don't fill this out: <input name="bot-field" /></label></p>
        <div class="two">
          <input class="field" type="text" name="first-name" placeholder="First name" autocomplete="given-name" required />
          <input class="field" type="text" name="last-name" placeholder="Last name" autocomplete="family-name" required />
        </div>
        <input class="field" type="email" name="email" placeholder="Email" autocomplete="email" required />
        <input class="field" type="tel" name="phone" placeholder="Phone" autocomplete="tel" />
        <textarea class="field" name="message" placeholder="What's going on?" rows="4" required></textarea>
        <button type="submit" class="send">Send message</button>
      </form>
    </div>
  </section>

  <section class="map-wrap">
    <iframe
      title={`Map to ${SITE.name}`}
      src="https://www.google.com/maps?q=3070+Leeman+Ferry+Rd+SW,+Huntsville,+AL&output=embed"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-head);
    font-weight: 700; font-size: 13px; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--blue-bright);
    margin-bottom: 1.2rem; display: block;
  }
  h1, h2 { font-family: var(--font-head); color: var(--navy); letter-spacing: -0.02em; margin: 0; }

  .contact {
    max-width: var(--maxw); margin: 0 auto; padding: 5.5rem 2rem 6rem;
    display: grid; grid-template-columns: 1fr; gap: 3.5rem;
  }
  .contact h1 { font-weight: 800; font-size: clamp(2.2rem, 4vw, 3.2rem); line-height: 1.05; margin-bottom: 1.6rem; }
  .contact .lead { font-size: 18px; line-height: 1.65; color: var(--muted); max-width: 48ch; margin: 0 0 2.75rem; }

  .details { display: flex; flex-direction: column; gap: 1.75rem; margin-bottom: 2.75rem; }
  .label {
    font-family: var(--font-head); font-weight: 700; font-size: 12.5px;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--steel); margin-bottom: 0.5rem;
  }
  .detail > a { color: var(--navy); font-size: 17px; font-weight: 600; }
  .detail > a:hover { color: var(--blue-bright); }
  .hours { display: flex; flex-direction: column; gap: 0.3rem; }
  .hour-row { display: flex; justify-content: space-between; max-width: 280px; font-size: 15px; color: var(--muted); }

  .form-panel { background: var(--bg-soft); border: 1px solid var(--line); padding: 2.5rem; }
  .form-panel h2 { font-weight: 700; font-size: 20px; margin-bottom: 0.4rem; }
  .form-note { font-size: 14.5px; color: var(--muted); margin: 0 0 1.75rem; }
  .contact-form { display: flex; flex-direction: column; gap: 1.1rem; }
  .two { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .hp { display: none; }
  .field {
    font-family: var(--font-body); font-size: 15px; padding: 0.8rem 0.9rem;
    border: 1px solid #d5d1c4; border-radius: var(--radius); background: var(--bg);
    color: var(--ink); width: 100%;
  }
  .field:focus { outline: 2px solid var(--blue-bright); outline-offset: 1px; }
  textarea.field { resize: vertical; }
  .send {
    font-family: var(--font-head); font-weight: 700; font-size: 15px;
    color: var(--bg); background: var(--navy); padding: 0.9rem 1.75rem;
    border: none; border-radius: var(--radius); cursor: pointer; transition: background 180ms ease;
  }
  .send:hover { background: #0d1733; }

  @media (min-width: 820px) {
    .contact { grid-template-columns: 1fr 1fr; gap: 4.5rem; }
  }

  .map-wrap { max-width: var(--maxw); margin: 0 auto 6rem; padding: 0 2rem; line-height: 0; }
  .map-wrap iframe { width: 100%; height: 380px; border: 0; border: 1px solid var(--line); }
</style>
