---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookNow from '../components/BookNow.astro';

const services = [
  { num: '01', title: 'Sports Chiropractic Adjustment', desc: 'Precise, targeted adjustments to restore joint motion and take pressure off irritated tissue — the foundation of every plan at Summit.', tags: ['Manual therapy', 'Joint mobility', 'Pain relief'], img: 'spinal-adjustment' },
  { num: '02', title: 'Movement Assessment', desc: 'A structured look at how you squat, run, lift, and rotate — so we treat the actual cause of pain, not just where it shows up.', tags: ['Screening', 'Root-cause', 'Athletes'], img: 'movement-assessment' },
  { num: '03', title: 'Dry Needling', desc: 'Thin filament needles placed into tight, irritated muscle to release tension and calm pain signals fast.', tags: ['Soft tissue', 'Recovery'], img: 'dry-needling' },
  { num: '04', title: 'Cupping Therapy', desc: 'Targeted suction therapy to increase blood flow and loosen restricted tissue around problem areas.', tags: ['Soft tissue', 'Recovery'], img: 'cupping-therapy' },
  { num: '05', title: 'Athletic Rehab', desc: 'Progressive, sport-specific rehab programming to rebuild strength and confidence after injury.', tags: ['Rehab', 'Youth athletes', 'Return-to-sport'], img: 'athletic-rehab' },
];
---

<BaseLayout title="Services" description="Sports chiropractic adjustments, movement assessment, dry needling, cupping, and athletic rehab at Summit Health & Performance in Huntsville, AL.">
  <section class="intro">
    <div class="eyebrow">Services</div>
    <h1>Every visit starts with why it's actually happening.</h1>
    <p class="lead">A focused set of tools, used deliberately — not a menu of add-ons.</p>
  </section>

  <section class="list">
    {services.map((s) => (
      <article class="svc">
        <div class="svc-thumb">
          <img src={`/images/photos/${s.img}.jpg`} alt={s.title} width="206" height="202" loading="lazy" />
        </div>
        <div class="svc-body">
          <div class="svc-num">{s.num}</div>
          <h2>{s.title}</h2>
          <p>{s.desc}</p>
          <div class="tags">
            {s.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        </div>
      </article>
    ))}
  </section>

  <section class="cta">
    <div class="cta-inner">
      <h2>Not sure which service fits?</h2>
      <p>Every visit starts with an assessment — we'll figure it out together.</p>
      <BookNow variant="on-navy" size="lg" />
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-head);
    font-weight: 700; font-size: 13px; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--blue-bright);
    margin-bottom: 1.2rem; display: block;
  }
  h1, h2 { font-family: var(--font-head); color: var(--navy); letter-spacing: -0.02em; margin: 0; }

  .intro { max-width: var(--maxw); margin: 0 auto; padding: 5.5rem 2rem 4rem; }
  .intro h1 { font-weight: 800; font-size: clamp(2.4rem, 4.4vw, 4rem); line-height: 1.04; max-width: 18ch; margin-bottom: 1.6rem; }
  .intro .lead { font-size: 19px; line-height: 1.65; color: var(--muted); max-width: 60ch; margin: 0; }

  .list { max-width: var(--maxw); margin: 0 auto; padding: 0 2rem 6rem; }
  .svc {
    display: grid; grid-template-columns: 1fr; gap: 1.5rem;
    align-items: start; padding: 3rem 0; border-top: 1px solid var(--line);
  }
  .svc-thumb { background: var(--bg-soft); border: 1px solid var(--line); padding: 0.6rem; width: 140px; }
  .svc-thumb img { width: 100%; height: auto; object-fit: cover; display: block; }
  .svc-num { font-family: var(--font-head); font-weight: 800; font-size: 15px; color: var(--blue-bright); margin-bottom: 1rem; }
  .svc-body h2 { font-weight: 800; font-size: clamp(1.6rem, 2.4vw, 2.1rem); letter-spacing: -0.01em; margin-bottom: 1.1rem; }
  .svc-body p { font-size: 17px; line-height: 1.7; color: var(--muted); max-width: 56ch; margin: 0 0 1.4rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .tag {
    font-size: 12.5px; font-weight: 600; color: var(--muted);
    background: var(--bg-soft); padding: 0.44rem 0.9rem;
    border-radius: var(--radius); border: 1px solid var(--line);
  }
  @media (min-width: 700px) { .svc { grid-template-columns: 140px 1fr; gap: 2.25rem; } }

  .cta { background: var(--navy); padding: 6rem 0; }
  .cta-inner { max-width: 900px; margin: 0 auto; padding: 0 2rem; text-align: center; }
  .cta h2 { font-weight: 800; font-size: clamp(2rem, 4vw, 3rem); color: var(--bg); margin-bottom: 1.4rem; }
  .cta p { font-size: 18px; color: var(--steel-light); max-width: 52ch; margin: 0 auto 2.5rem; line-height: 1.6; }
</style>
