---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookNow from '../components/BookNow.astro';
import { SITE } from '../data/site';

const services = [
  { num: '01', title: 'Sports Chiropractic', desc: 'Precise adjustments targeting the joints and segments driving your pain or restriction.' },
  { num: '02', title: 'Movement Assessment', desc: 'A full look at how you move — not just where it hurts — to find the actual root cause.' },
  { num: '03', title: 'Dry Needling & Cupping', desc: 'Targeted soft-tissue work to release tension and speed recovery between sessions.' },
];

const stats = [
  { big: 'Root-cause', small: 'care, not band-aids' },
  { big: 'Athletes', small: 'youth to weekend warriors' },
  { big: '1-on-1', small: 'time with Dr. Graham' },
  { big: 'Huntsville', small: '3070 Leeman Ferry Rd SW' },
];
---

<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-copy">
      <div class="eyebrow">Sports Chiropractic · Huntsville, AL</div>
      <h1>Move better.<br />Perform higher.<br />Train without limits.</h1>
      <p class="lead">
        Dr. Seth Graham helps active adults and youth athletes find and fix the root cause
        of pain — so it stays fixed.
      </p>
      <div class="hero-actions">
        <BookNow />
        <a href="/services/" class="text-link">See our services →</a>
      </div>
    </div>
    <figure class="hero-photo">
      <img
        src="/images/photos/clinic-treatment.jpg"
        alt="Chiropractic treatment session at Summit Health & Performance"
        width="306"
        height="409"
        fetchpriority="high"
      />
      <figcaption>In-clinic session</figcaption>
    </figure>
  </section>

  <!-- STAT STRIP -->
  <section class="stat-strip-wrap">
    <div class="stat-strip">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat-big">{s.big}</div>
          <div class="stat-small">{s.small}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services">
    <div class="services-inner">
      <div class="services-head">
        <div>
          <div class="eyebrow">What we do</div>
          <h2>Care built around how you move.</h2>
        </div>
        <a href="/services/" class="text-link">All services →</a>
      </div>
      <div class="services-grid">
        {services.map((s) => (
          <div class="service">
            <div class="service-num">{s.num}</div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT / DOCTOR STRIP -->
  <section class="doctor">
    <figure class="doctor-photo">
      <img src="/images/photos/dr-graham-headshot.jpg" alt="Dr. Seth Graham" width="431" height="618" loading="lazy" />
    </figure>
    <div class="doctor-copy">
      <div class="eyebrow">Your Doctor</div>
      <h2>Dr. Seth Graham</h2>
      <p>
        Sports chiropractic isn't about quick cracks — it's a deliberate process of assessment,
        adjustment, and rebuilding capacity. Dr. Graham blends manual care with movement-based
        rehab so patients leave with a plan, not just relief.
      </p>
      <p>
        Every visit starts with the same question: what's actually causing this — and how do we
        make sure it doesn't come back.
      </p>
      <a href="/about/" class="text-link">More about Dr. Graham →</a>
    </div>
  </section>

  <!-- CTA NAVY -->
  <section class="cta">
    <div class="cta-inner">
      <h2>Ready to move without limits?</h2>
      <p>Book your first visit and let's build a plan around the root cause — not just the symptom.</p>
      <BookNow variant="on-navy" size="lg" />
    </div>
  </section>
</BaseLayout>

<style>
  /* Shared bits */
  .eyebrow {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--blue-bright);
    margin-bottom: 1rem;
    display: block;
  }
  h1, h2 {
    font-family: var(--font-head);
    letter-spacing: -0.015em;
    color: var(--navy);
    margin: 0;
  }
  .text-link {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 15px;
    color: var(--navy);
    padding-bottom: 5px;
    border-bottom: 2px solid var(--steel-light);
    white-space: nowrap;
    transition: border-color 160ms ease;
  }
  .text-link:hover { border-color: var(--blue-bright); color: var(--navy); }

  /* HERO */
  .hero {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 5.5rem 2rem 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: end;
  }
  .hero h1 {
    font-weight: 800;
    font-size: clamp(2.6rem, 4.6vw, 4.6rem);
    line-height: 1.02;
    margin-bottom: 1.6rem;
  }
  .hero .lead {
    font-size: 19px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 46ch;
    margin: 0 0 2.2rem;
  }
  .hero-actions { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
  .hero-photo {
    margin: 0;
    background: var(--bg-soft);
    padding: 1.25rem;
    border: 1px solid var(--line);
    justify-self: start;
    max-width: 320px;
  }
  .hero-photo img {
    width: 100%;
    max-width: 260px;
    height: auto;
    object-fit: cover;
    display: block;
    margin: 0 auto;
  }
  .hero-photo figcaption {
    font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
    font-size: 11px;
    color: var(--steel);
    text-align: center;
    margin-top: 0.9rem;
    letter-spacing: 0.02em;
  }
  @media (min-width: 860px) {
    .hero { grid-template-columns: 1.25fr 0.75fr; gap: 3.5rem; padding-top: 5.5rem; }
    .hero-photo { justify-self: stretch; max-width: none; }
  }

  /* STAT STRIP */
  .stat-strip-wrap { max-width: var(--maxw); margin: 4rem auto 0; padding: 0 2rem; }
  .stat-strip {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .stat { background: var(--bg); padding: 2rem 1.75rem; }
  .stat-big {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    color: var(--navy);
    letter-spacing: -0.02em;
  }
  .stat-small { font-size: 14px; color: var(--muted); margin-top: 0.4rem; }
  @media (min-width: 780px) {
    .stat-strip { grid-template-columns: repeat(4, 1fr); }
  }

  /* SERVICES */
  .services { background: var(--bg-soft); padding: 6rem 0; margin-top: 4rem; }
  .services-inner { max-width: var(--maxw); margin: 0 auto; padding: 0 2rem; }
  .services-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }
  .services-head h2 { font-weight: 800; font-size: clamp(1.9rem, 3vw, 2.6rem); }
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .service {
    background: var(--bg);
    padding: 2.5rem 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .service-num { font-family: var(--font-head); font-weight: 800; font-size: 15px; color: var(--blue-bright); }
  .service h3 { font-family: var(--font-head); font-weight: 700; font-size: 20px; color: var(--navy); margin: 0; }
  .service p { font-size: 15px; line-height: 1.65; color: var(--muted); margin: 0; }
  @media (min-width: 780px) {
    .services-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* DOCTOR STRIP */
  .doctor {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 6.5rem 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  .doctor-photo {
    margin: 0;
    background: var(--bg-soft);
    padding: 1.1rem;
    border: 1px solid var(--line);
    max-width: 300px;
  }
  .doctor-photo img { width: 100%; height: auto; object-fit: cover; display: block; }
  .doctor-copy h2 { font-weight: 800; font-size: clamp(1.9rem, 3vw, 2.5rem); margin-bottom: 1.4rem; }
  .doctor-copy p { font-size: 18px; line-height: 1.7; color: var(--muted); max-width: 56ch; margin: 0 0 1.3rem; }
  .doctor-copy .text-link { display: inline-block; margin-top: 0.5rem; }
  @media (min-width: 860px) {
    .doctor { grid-template-columns: 0.85fr 1.15fr; gap: 4rem; }
  }

  /* CTA */
  .cta { background: var(--navy); padding: 6rem 0; }
  .cta-inner { max-width: 900px; margin: 0 auto; padding: 0 2rem; text-align: center; }
  .cta h2 {
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--bg);
    margin-bottom: 1.4rem;
  }
  .cta p { font-size: 18px; color: var(--steel-light); max-width: 52ch; margin: 0 auto 2.5rem; line-height: 1.6; }
</style>
